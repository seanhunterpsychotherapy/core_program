    <!-- SELF-CARE -->
    <div class="passage" id="selfcare">
      <p class="prompt">Self-care is not a luxury — it's regulation, healing, and protection for your recovery.</p>
      <p class="sub-prompt">Which area feels most depleted or neglected right now?</p>
      <div class="choices">
        <button class="choice" onclick="go('sc-physical')">Physical — sleep, food, movement, basic health</button>
        <button class="choice" onclick="go('sc-emotional')">Emotional — managing how I feel, calming myself</button>
        <button class="choice" onclick="go('sc-meaning')">Meaning & purpose — I feel disconnected from what matters</button>
